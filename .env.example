# ─────────────────────────────────────────────
# MOLIT (국토교통부) Open API Key
# ─────────────────────────────────────────────
# 1. Register at https://www.data.go.kr
# 2. Search for "국토교통부 아파트매매 실거래 상세 자료"
# 3. Apply for the API key (instant approval)
# 4. Paste your key below
#
# Without a key, the app runs on realistic mock data automatically.
MOLIT_API_KEY=

# Set to "true" to force mock data even when API key is present
USE_MOCK_DATA=false
